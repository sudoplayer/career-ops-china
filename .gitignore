# ============================================================
# career-ops-china — gitignore
# ============================================================

# === Personal data (user fills these locally, never commit) ===
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
outreach/*.md
!outreach/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/*.tsv
batch/tracker-additions/merged/
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# === Browser bookmarklet inbox（本地 JD 捕获，含真实公司数据）===
inbox/*
!inbox/.gitkeep
!inbox/processed/.gitkeep

# === User config (copy from templates/*.example.yml) ===
config/profile.yml
portals.yml

# === Personal CV and proof points (privacy) ===
cv.md
article-digest.md
# (interview-prep/story-bank.md is gitignored under the interview-prep section below)

# === Generated / build artifacts ===
.resolved-prompt-*
node_modules/
career-dashboard

# === Logs ===
logs/
*.log
npm-debug.log*

# === Process files ===
pids/
*.pid
*.pid.lock

# === Environment files ===
.env
.env.*
!.env.example

# === npm / yarn cache ===
.npm
.yarn-integrity

# === OS ===
.DS_Store
*.mov
*.mp4

# === Claude Code local ===
.claude/settings.local.json
.claude/memory/
.claude

# === .playwright-mcp ===
.playwright-mcp


# === interview-prep ===
interview-prep/mock-interviews/*
interview-prep/story-bank.md
